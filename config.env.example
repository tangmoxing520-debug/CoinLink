# Copy this file to `config.env` and fill in your secrets locally.
# NOTE: `config.env` is gitignored by default.

# ========== Exchange ==========
EXCHANGE=binance

# ========== Binance (Futures) ==========
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_FUTURES_API_URL=https://fapi.binance.com/fapi/v1
VERIFY_SSL=true
REQUEST_TIMEOUT=30

# Trade mode: virtual | real
TRADE_MODE=virtual
TRADE_ENABLED=false

# ========== DingTalk ==========
DINGTALK_WEBHOOK=
DINGTALK_SECRET=
DINGTALK_NOTIFY_ALERTS=false
DINGTALK_NOTIFY_TRADES=true
DINGTALK_NOTIFY_IN_VIRTUAL=true

# ========== Backtest / Live alignment defaults ==========
BACKTEST_INTERVAL=15m
SIGNAL_TRIGGER_INTERVAL=15m
MONITOR_ENABLED_CATEGORIES=SOL,Meme,AI Agent,AI Agency,Layer1,Layer2,RWA
TRADE_LEADER_COIN=false

# V6 core params
LEVERAGE=15
V2_TAKE_PROFIT=8
V2_STOP_LOSS=4
V2_TRAILING_STOP_PCT=1.5
V2_TRAILING_STOP_ACTIVATION=2.5
V2_MAX_POSITIONS=8
V2_COOLDOWN_PERIODS=2
V2_BASE_TRADE_AMOUNT=500
V2_MAX_TRADE_AMOUNT=2500

# ========== Signal calibrator (entry gate) ==========
# These thresholds are applied BEFORE opening a position (after raw score is computed).
# Conservative defaults:
# - normal_min_score=70
# - bearish_min_score=80
# To increase entries during "crash then rebound" periods, consider lowering them modestly.
CALIBRATOR_NORMAL_MIN_SCORE=70
CALIBRATOR_BEARISH_MIN_SCORE=80

# ========== P0优化：分批止盈配置 ==========
# 是否启用分批止盈（默认: true）
PARTIAL_TP_ENABLED=true
# 分批止盈级别（杠杆后收益率: 10%, 20%, 30%）
PARTIAL_TP_LEVELS=10,20,30
# 每级止盈比例（33%, 33%, 34%）
PARTIAL_TP_RATIOS=0.33,0.33,0.34

# ========== P0优化：最大回撤硬止损 ==========
# 最大回撤阈值（达到此回撤暂停新开仓，默认: 20.0%）
MAX_DRAWDOWN_THRESHOLD=20.0
# 最大回撤动作（pause=暂停交易, stop=完全停止）
MAX_DRAWDOWN_ACTION=pause
# 严重回撤阈值（达到此回撤完全停止交易并平仓，默认: 30.0%）
MAX_DRAWDOWN_SEVERE_THRESHOLD=30.0

# ========== P0优化：单日亏损限制 ==========
# 单日最大亏损阈值（达到此亏损暂停新开仓，默认: 5.0%）
MAX_DAILY_LOSS=5.0
# 单日亏损动作（pause=暂停交易, stop=完全停止）
MAX_DAILY_LOSS_ACTION=pause
# 严重单日亏损阈值（达到此亏损完全停止交易并平仓，默认: 10.0%）
MAX_DAILY_LOSS_SEVERE=10.0

# ========== P0优化：市场异常检测 ==========
# 是否启用市场异常检测（默认: true）
MARKET_ANOMALY_ENABLED=true
# 闪崩检测阈值（5分钟内下跌>此百分比视为闪崩，默认: 20.0%）
FLASH_CRASH_THRESHOLD=20.0
# 闪崩检测窗口（分钟，默认: 5）
FLASH_CRASH_WINDOW_MINUTES=5
# 流动性异常阈值（成交量下降>此百分比视为流动性异常，默认: 80.0%）
LIQUIDITY_DROP_THRESHOLD=80.0

